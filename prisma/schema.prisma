generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model campo {
  id             Int            @id @default(autoincrement())
  id_tipo_tarefa Int?
  nome           String         @db.VarChar(100)
  descricao      String         @db.VarChar(255)
  obrigatorio    Boolean        @default(false)
  tipo           String         @db.VarChar(100)
  tipo_label     String         @db.VarChar(100)
  opcoes         String[]       @db.VarChar(100)
  valor          String?
  tipo_tarefa    tipo_tarefa?   @relation(fields: [id_tipo_tarefa], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tarefa_campo   tarefa_campo[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model coluna {
  id            Int      @id @default(autoincrement())
  id_espaco     Int
  nome          String   @db.VarChar(255)
  tipo          String   @db.VarChar(50)
  data_cadastro DateTime @default(now()) @db.Timestamptz(6)
  ordem         Int
  ativo         Boolean  @default(true)
  espaco        espaco   @relation(fields: [id_espaco], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tarefa        tarefa[]
}

model email_log {
  id             Int             @id @default(autoincrement())
  id_usuario     Int
  email          String          @db.VarChar(100)
  assunto        String          @db.VarChar(100)
  corpo          String
  data_cadastro  DateTime        @default(now()) @db.Timestamptz(6)
  id_convite     Int?
  erro           String?
  espaco_convite espaco_convite? @relation(fields: [id_convite], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario        usuario         @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model espaco {
  id                        Int                         @id @default(autoincrement())
  id_usuario                Int
  nome                      String                      @db.VarChar(50)
  descricao                 String                      @db.VarChar(255)
  sigla                     String                      @db.Char(2)
  icon                      String                      @db.VarChar(100)
  ativo                     Boolean?                    @default(true)
  coluna                    coluna[]
  usuario                   usuario                     @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
  espaco_convite            espaco_convite[]
  espaco_usuario            espaco_usuario[]
  espaco_usuario_permissoes espaco_usuario_permissoes[]
  tarefa                    tarefa[]
  tipo_tarefa               tipo_tarefa[]
}

model espaco_convite {
  id                Int                   @id @default(autoincrement())
  id_espaco         Int
  id_usuario        Int
  status            espaco_convite_status @default(PENDENTE)
  enviar_email      Boolean?              @default(false)
  data_cadastro     DateTime              @default(now()) @db.Timestamptz(6)
  data_expiracao    DateTime              @default(now()) @db.Timestamp(6)
  data_aceite       DateTime?             @db.Timestamptz(6)
  data_recusa       DateTime?             @db.Timestamptz(6)
  data_cancelamento DateTime?             @db.Timestamp(6)
  email_log         email_log[]
  espaco            espaco                @relation(fields: [id_espaco], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario           usuario               @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model espaco_permissoes {
  id                        Int                         @id @default(autoincrement())
  nome                      String?                     @db.VarChar(50)
  descricao                 String?
  data_cadastro             DateTime                    @default(now()) @db.Timestamptz(6)
  espaco_usuario_permissoes espaco_usuario_permissoes[]
}

model espaco_usuario {
  id            Int       @id @default(autoincrement())
  id_usuario    Int
  id_espaco     Int
  permissoes    String[]
  ativo         Boolean?  @default(true)
  data_cadastro DateTime? @default(now()) @db.Timestamp(6)
  espaco        espaco    @relation(fields: [id_espaco], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario       usuario   @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model espaco_usuario_permissoes {
  id                Int               @id @default(autoincrement())
  id_permissao      Int
  id_usuario        Int
  id_espaco         Int
  escrita           Boolean?          @default(false)
  data_cadastro     DateTime          @default(now()) @db.Timestamptz(6)
  espaco            espaco            @relation(fields: [id_espaco], references: [id], onDelete: NoAction, onUpdate: NoAction)
  espaco_permissoes espaco_permissoes @relation(fields: [id_permissao], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario           usuario           @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id_usuario, id_espaco, id_permissao], map: "unique_usuario_espaco_permissao")
}

model migrations {
  nome_arquivo String @id @db.VarChar(200)
}

model tarefa {
  id               Int              @id @default(autoincrement())
  titulo           String           @db.VarChar(255)
  descricao        String?
  data_cadastro    DateTime         @default(now()) @db.Timestamptz(6)
  data_atualizacao DateTime         @default(now()) @db.Timestamptz(6)
  id_espaco        Int?
  id_coluna        Int?
  ordem            Int
  id_responsavel   Int?
  data_prevista    DateTime?        @db.Date
  data_limite      DateTime?        @db.Date
  espaco           espaco?          @relation(fields: [id_espaco], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tarefa_espaco")
  coluna           coluna?          @relation(fields: [id_coluna], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario          usuario?         @relation(fields: [id_responsavel], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tarefa_arquivo   tarefa_arquivo[]
}

model tarefa_arquivo {
  id            Int      @id @default(autoincrement())
  id_tarefa     Int?
  id_opera      Int?
  nome          String   @db.VarChar(255)
  data_cadastro DateTime @default(now()) @db.Timestamptz(6)
  public_url    String?
  tarefa        tarefa?  @relation(fields: [id_tarefa], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model tarefa_campo {
  id          Int     @id @default(autoincrement())
  id_campo    Int
  obrigatorio Boolean @default(false)
  valor       String?
  campo       campo   @relation(fields: [id_campo], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model tipo_tarefa {
  id        Int     @id @default(autoincrement())
  icone     String? @db.VarChar(100)
  nome      String  @db.VarChar(100)
  descricao String
  id_espaco Int?
  campo     campo[]
  espaco    espaco? @relation(fields: [id_espaco], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model usuario {
  id                        Int                         @id @default(autoincrement())
  nome                      String                      @db.VarChar(255)
  avatar_public_url         String?
  email                     String                      @db.VarChar(100)
  senha                     String?                     @db.VarChar(100)
  data_cadastro             DateTime                    @default(now()) @db.Timestamptz(6)
  ativo                     Boolean?                    @default(true)
  username                  String                      @unique @db.VarChar(15)
  provedor                  String                      @default("credentials") @db.VarChar(100)
  email_log                 email_log[]
  espaco                    espaco[]
  espaco_convite            espaco_convite[]
  espaco_usuario            espaco_usuario[]
  espaco_usuario_permissoes espaco_usuario_permissoes[]
  tarefa                    tarefa[]
}

enum espaco_convite_status {
  PENDENTE
  ACEITO
  RECUSADO
  CANCELADO
}
